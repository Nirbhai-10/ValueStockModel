{
    "functions": {
        "api/index.js": {
            "includeFiles": [
                "data/**",
                "../public/**"
            ]
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ]
}